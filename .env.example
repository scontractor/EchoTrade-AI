# ── LLM Backend (OpenAI-compatible) ────────────────────────────────────────
# Default: Ollama running locally — no key required, fully private
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=llama3.1:8b

# ── Hosted open-source alternatives (uncomment one block) ──────────────────

# Groq (free tier, fast) — models: llama-3.3-70b-versatile, mixtral-8x7b-32768
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_API_KEY=gsk_...
# LLM_MODEL=llama-3.3-70b-versatile

# Together AI (free tier) — models: meta-llama/Llama-3.3-70B-Instruct-Turbo
# LLM_BASE_URL=https://api.together.xyz/v1
# LLM_API_KEY=...
# LLM_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo

# OpenRouter (many models)
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_API_KEY=sk-or-...
# LLM_MODEL=meta-llama/llama-3.3-70b-instruct

# ── Optional ────────────────────────────────────────────────────────────────
# NewsAPI key — increases sentiment headline quota (https://newsapi.org free tier)
NEWSAPI_KEY=

# Server
HOST=0.0.0.0
PORT=8000
